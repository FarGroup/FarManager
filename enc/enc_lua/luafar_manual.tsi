#_  strVersion: either of "XP", "XPSP1", "XPSP2", "XPSP3", "Vista", "VistaSP1",
#_              "VistaSP2", "W7", "W7SP1", "W8", "W8.1", "W10", "Server".
#_              This parameter is case insensitive.
#_
