article id=68 dt=Text ctime=0 mtime=3602448401 nm=far.PluginStartupInfo
#_Info = far.PluginStartupInfo ()
#_
#_**Parameters:**
#_  none
#_
#_**Returns:**
#_  Info: table
#_    fields of Info:
#_      ModuleName:   string
#_      ModuleDir:    string (has a backslash at the end)
#_      PluginGuid:   string
#_
