article id=567 dt=Text ctime=3917945155 mtime=3968044811 nm=actl namespace
#_This is an alternative interface to FAR's advanced control commands.
#_It is shorter and more expressive, e.g. the following 2 calls do the
#_same thing:
#_    1) info = far.AdvControl("ACTL_GETWINDOWINFO", 2)
#_    2) info = actl.GetWindowInfo(2)
#_
#_**actl** is a global table containing those alternative functions.
#_Below is a table of correspondence between **ACTL_** messages
#_and functions from the **actl** table:
#_
#_  Commit                  ACTL_COMMIT
#_  GetArrayColor           ACTL_GETARRAYCOLOR
#_  GetColor                ACTL_GETCOLOR
#_  GetCursorPos            ACTL_GETCURSORPOS
#_  GetFarHwnd              ACTL_GETFARHWND
#_  GetFarManagerVersion    ACTL_GETFARMANAGERVERSION
#_  GetFarRect              ACTL_GETFARRECT
#_  GetWindowCount          ACTL_GETWINDOWCOUNT
#_  GetWindowInfo           ACTL_GETWINDOWINFO
#_  GetWindowType           ACTL_GETWINDOWTYPE
#_  ProgressNotify          ACTL_PROGRESSNOTIFY
#_  Quit                    ACTL_QUIT
#_  RedrawAll               ACTL_REDRAWALL
#_  SetArrayColor           ACTL_SETARRAYCOLOR
#_  SetCurrentWindow        ACTL_SETCURRENTWINDOW
#_  SetCursorPos            ACTL_SETCURSORPOS
#_  SetProgressState        ACTL_SETPROGRESSSTATE
#_  SetProgressValue        ACTL_SETPROGRESSVALUE
#_  Synchro                 ACTL_SYNCHRO
#_  WaitKey                 ACTL_WAITKEY
#_
#_@@@
#_{actl_commit}: $(ENC_URL)/service_functions/advcontrol.html#ACTL_COMMIT
#_{actl_getarraycolor}: $(ENC_URL)/service_functions/advcontrol.html#ACTL_GETARRAYCOLOR
#_{actl_getcolor}: $(ENC_URL)/service_functions/advcontrol.html#ACTL_GETCOLOR
#_{actl_getcursorpos}: $(ENC_URL)/service_functions/advcontrol.html#ACTL_GETCURSORPOS
#_{actl_getfarhwnd}: $(ENC_URL)/service_functions/advcontrol.html#ACTL_GETFARHWND
#_{actl_getfarmanagerversion}: $(ENC_URL)/service_functions/advcontrol.html#ACTL_GETFARMANAGERVERSION
#_{actl_getfarrect}: $(ENC_URL)/service_functions/advcontrol.html#ACTL_GETFARRECT
#_{actl_getwindowcount}: $(ENC_URL)/service_functions/advcontrol.html#ACTL_GETWINDOWCOUNT
#_{actl_getwindowinfo}: $(ENC_URL)/service_functions/advcontrol.html#ACTL_GETWINDOWINFO
#_{actl_getwindowtype}: $(ENC_URL)/service_functions/advcontrol.html#ACTL_GETWINDOWTYPE
#_{actl_progressnotify}: $(ENC_URL)/service_functions/advcontrol.html#ACTL_PROGRESSNOTIFY
#_{actl_quit}: $(ENC_URL)/service_functions/advcontrol.html#ACTL_QUIT
#_{actl_redrawall}: $(ENC_URL)/service_functions/advcontrol.html#ACTL_REDRAWALL
#_{actl_setarraycolor}: $(ENC_URL)/service_functions/advcontrol.html#ACTL_SETARRAYCOLOR
#_{actl_setcurrentwindow}: $(ENC_URL)/service_functions/advcontrol.html#ACTL_SETCURRENTWINDOW
#_{actl_setcursorpos}: $(ENC_URL)/service_functions/advcontrol.html#ACTL_SETCURSORPOS
#_{actl_setprogressstate}: $(ENC_URL)/service_functions/advcontrol.html#ACTL_SETPROGRESSSTATE
#_{actl_setprogressvalue}: $(ENC_URL)/service_functions/advcontrol.html#ACTL_SETPROGRESSVALUE
#_{actl_synchro}: $(ENC_URL)/service_functions/advcontrol.html#ACTL_SYNCHRO
#_{actl_waitkey}: $(ENC_URL)/service_functions/advcontrol.html#ACTL_WAITKEY
#_{advcontrol}: $(ENC_URL)/service_functions/advcontrol.html
#_

