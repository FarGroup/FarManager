#_    table
#_      GetType: integer
#_      ValType: integer (enum FARMACROVARTYPE)
#_      Value:   nil, flags, string, or number (depends on ValType)
#_
#_**Return**
#_    table
#_      ValType: integer (enum FARMACROVARTYPE)
#_      Value:   flags, string, or number (depends on ValType)
