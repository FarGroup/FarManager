article id=15 dt=Text ctime=0 mtime=3726225783 nm=panel.SetUserScreen
#_result = panel.SetUserScreen ([handle], [scrolltype])
#_
#_**Parameters:**
#_  handle:     panel handle
#_  scrolltype: integer (defaults to 0)
#_
#_**Returns:**
#_  result: boolean
#_
#_**Far API used:**
#_  PanelControl, FCTL_SETUSERSCREEN
#_
#_**Example:**
#_  function printToFARConsole(...)
#_    panel.GetUserScreen()
#_    io.write(...)
#_    io.write("\n")
#_    panel.SetUserScreen()
#_  end
#_
#_@@@
#_{fctl_setuserscreen}: $(ENC_URL)/service_functions/panelcontrol.html#FCTL_SETUSERSCREEN
#_{panelcontrol}: $(ENC_URL)/service_functions/panelcontrol.html
#_

