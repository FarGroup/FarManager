article id=598 dt=Text ctime=3972662101 mtime=3972662773 nm=Buffer:write
#_len = Buffer:write (Index, Text, Color)
#_
#_**Parameters:**
#_  Buffer : user control (userdata)
#_  Index  : integer
#_  Text   : string
#_  Color  : table `tFarColor` or integer
