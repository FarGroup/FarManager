article id=490 dt=Text ctime=3585338276 mtime=3605129666 nm=far.CreateUserControl
#_<markdown>
#_Buffer support for `DI_USERCONTROL`. Use it like this:
#_
#_```
#_local buffer=far.CreateUserControl(10,10)
#_local textel={Char="a",Attributes={Flags=bit64.bor(F.FCF_FG_INDEX,F.FCF_BG_INDEX),ForegroundColor=9,BackgroundColor=8}}
#_for ii=1,#buffer do
#_  buffer[ii]=textel
#_end
#_local items={
#_  {"DI_DOUBLEBOX",0,0,11,11,0,0,0,0,""},
#_  {"DI_USERCONTROL",1,1,10,10,buffer,0,0,0,""}
#_}
#_```
#_
#_@@@
#_{di_usercontrol}: $(ENC_URL)/dialogapi/controls/di_usercontrol.html
